# 应用基础
APP_HOST=127.0.0.1
APP_PORT=8001
APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=text
AGENT_HOST=127.0.0.1
AGENT_PORT=8000

# 知识库后端 DeepSeek 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 文创 Agent DeepSeek 配置
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# 阿里 DashScope / MAAS Embedding
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://ws-n81tu3iqo4jsalm2.cn-beijing.maas.aliyuncs.com/api/v1
EMBEDDING_DASHSCOPE_URL=https://ws-n81tu3iqo4jsalm2.cn-beijing.maas.aliyuncs.com/api/v1
EMBEDDING_MODEL=qwen3-vl-embedding

# 阿里 DashScope / MAAS Rerank
RERANK_API_KEY=
RERANK_BASE_URL=https://ws-n81tu3iqo4jsalm2.cn-beijing.maas.aliyuncs.com/api/v1
RERANK_MODEL=qwen3-rerank
RERANK_ENABLED=false

# Chroma
CHROMA_PATH=backend/data/chroma
CHROMA_COLLECTION=tourism_knowledge_vectors
MIN_RETRIEVAL_CONFIDENCE=0.7

# 文创 Agent 检索来源
RETRIEVER_PROVIDER=shujuku
SHUJUKU_SEARCH_URL=http://127.0.0.1:8001/api/v1/search
SHUJUKU_USER_TYPE=visitor
SHUJUKU_SEARCH_TIMEOUT=15

# 文创 Agent Mock 知识库，RETRIEVER_PROVIDER=mock 时使用
MOCK_KNOWLEDGE_PATH=agent/wc_agent/data/sample_knowledge.jsonl

# 文件解析 / OCR
PARSER_OCR_PROVIDER=none
PARSER_OCR_API_KEY=
PARSER_OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PARSER_OCR_MODEL=qwen-vl-ocr
