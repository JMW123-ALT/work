# ── Application ────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=text

# ── PostgreSQL v2 (REQUIRED) ────────────────────────────────────────────────
# v1 SQLite data chain has been removed; PostgreSQL is now the only runtime DB.
# asyncpg for SQLAlchemy async engine (runtime):
DATABASE_URL=postgresql+asyncpg://root:root@127.0.0.1:5432/wenchuang
# psycopg3 for Alembic sync migrations:
DATABASE_URL_SYNC=postgresql+psycopg://root:root@127.0.0.1:5432/wenchuang

# Default organization for single-org local mode.
# The API layer injects this automatically — frontend does NOT pass organization_id.
DEFAULT_ORGANIZATION_ID=00000000-0000-4000-8000-00000000a001

# ── Redis / Celery (NOT needed — BackgroundTasks is used instead) ───────────
# Uncomment only when migrating to Celery in production.
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1

# ── Chroma v2 ─────────────────────────────────────────────────────────────
# v1 collection wenchuang_knowledge is no longer used.
CHROMA_COLLECTION_V2=wenchuang_knowledge_v2
CHROMA_PATH=backend/data/chroma
CHROMA_DISTANCE_SPACE=cosine

# ── Paths ──────────────────────────────────────────────────────────────────
DATA_DIR=backend/data
UPLOAD_DIR=backend/data/uploads

# ── DeepSeek LLM ───────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Embedding (DashScope / MAAS) ───────────────────────────────────────────
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=your-dashscope-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1
EMBEDDING_MODEL=text-embedding-v3

# ── Rerank ─────────────────────────────────────────────────────────────────
RERANK_PROVIDER=passthrough
RERANK_ENABLED=false
RERANK_API_KEY=
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1
RERANK_MODEL=gte-rerank

# ── OCR (optional) ────────────────────────────────────────────────────────
PARSER_OCR_PROVIDER=none

# First-stage platform infrastructure placeholders
DATABASE_URL=postgresql+asyncpg://wenchuang:wenchuang@localhost:5432/wenchuang
DATABASE_URL_SYNC=postgresql+psycopg://wenchuang:wenchuang@localhost:5432/wenchuang
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Alibaba DashScope / MAAS Embedding
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://ws-n81tu3iqo4jsalm2.cn-beijing.maas.aliyuncs.com/api/v1
EMBEDDING_DASHSCOPE_URL=https://ws-n81tu3iqo4jsalm2.cn-beijing.maas.aliyuncs.com/api/v1
EMBEDDING_MODEL=qwen3-vl-embedding

# Alibaba DashScope / MAAS Rerank
RERANK_PROVIDER=dashscope
RERANK_API_KEY=
RERANK_BASE_URL=https://ws-n81tu3iqo4jsalm2.cn-beijing.maas.aliyuncs.com/api/v1
RERANK_MODEL=qwen3-vl-rerank
RERANK_ENABLED=true

# Local knowledge store shared by ingestion, RAG, and Wenchuang Agent
DATA_DIR=backend/data
UPLOAD_DIR=backend/data/uploads
CHROMA_PATH=backend/data/chroma
CHROMA_COLLECTION=wenchuang_knowledge
CHROMA_COLLECTION_V2=wenchuang_knowledge_v2
MIN_RETRIEVAL_CONFIDENCE=0.7

# File parsing / OCR
PARSER_OCR_PROVIDER=none
PARSER_OCR_API_KEY=
PARSER_OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PARSER_OCR_MODEL=qwen-vl-ocr

# ── 图片生成 API（8848，OpenAI-compatible）─────────────────────────────────
IMAGE_API_BASE_URL=https://api.884819.xyz/v1
IMAGE_API_KEY=
IMAGE_API_TIMEOUT=180
IMAGE_API_DEFAULT_MODEL=gpt-image-2
IMAGE_API_MODELS=gemini-3.1-flash-image,gpt-image-2,grok-imagine-image,grok-imagine-image-quality

# ── Pexels 图片搜索 API（文章配图检索）─────────────────────────────────────
# 免费申请：https://www.pexels.com/api/
PEXELS_API_KEY=
PEXELS_BASE_URL=https://api.pexels.com/v1
PEXELS_TIMEOUT=15
